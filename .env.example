# ══════════════════════════════════════════════════════════════
#  Dr. NutriCare — Root .env
#  Copy this to .env and fill in real values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# OpenRouter API key — https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deployer wallet private key (hex, with 0x prefix)
# Use a DEDICATED TEST WALLET — NEVER your main wallet
PRIVATE_KEY=0xYOUR_64_CHAR_HEX_PRIVATE_KEY_HERE

# Polygon Amoy Testnet RPC
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Deployed MedicalIntegrity contract address (set after: npm run deploy)
INTEGRITY_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE
