# ══════════════════════════════════════════════════════════════════════════════
#  MedNutri · Environment Variables
#  Copy this file to .env.local and fill in real values.
#  NEVER commit .env.local to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── AI (OpenRouter) ───────────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Blockchain · Polygon Amoy Testnet ─────────────────────────────────────────

# RPC endpoint — get a free key at https://www.alchemy.com/ or https://www.infura.io/
# Alchemy format:  https://polygon-amoy.g.alchemy.com/v2/<YOUR_KEY>
# Infura format:   https://polygon-amoy.infura.io/v3/<YOUR_KEY>
# Public fallback: https://rpc-amoy.polygon.technology  (less reliable, ok for dev)
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key of the Admin Wallet that owns the MedicalRegistry contract.
# This wallet needs a small amount of MATIC on Amoy Testnet for gas fees.
# Get free testnet MATIC at: https://faucet.polygon.technology/
# ⚠️  Use a DEDICATED TEST WALLET — NEVER your real wallet private key.
ADMIN_PRIVATE_KEY=0xYOUR_64_CHAR_HEX_PRIVATE_KEY_HERE

# Address of the deployed MedicalRegistry.sol contract on Polygon Amoy.
# Deploy it via Remix IDE or Hardhat and paste the address here.
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE
  
# AI Microservices  
MEDGEMMA_SERVICE_URL=http://localhost:8100  
BIOBERT_SERVICE_URL=http://localhost:8200  
